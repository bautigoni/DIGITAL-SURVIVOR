# ─────────────────────────────────────────────────────────────
# Digital Survivor – variables de entorno para producción
# Copiar a .env y completar antes de `docker compose up -d`.
# ─────────────────────────────────────────────────────────────

# Dominio público (Caddy lo enruta vía TLS automático)
PUBLIC_DOMAIN=digitalsurvivor.bauhub.online

# CORS: quién puede pegarle a /api desde el browser
# En prod mismo dominio: agregamos el https://...
CORS_ORIGIN=https://digitalsurvivor.bauhub.online

# Postgres (dentro de la red del compose: el host es el nombre del service `db`)
POSTGRES_USER=digitalsurvivor
POSTGRES_PASSWORD=cambiame-en-produccion
POSTGRES_DB=digitalsurvivor

# JWT: 32+ chars aleatorios
JWT_SECRET=cambiame-en-produccion-32-chars-minimo-aaaaaaaaaaaaaaaa

# IA procedural: heuristic = 0 dependencias externas
AI_PROVIDER=heuristic
